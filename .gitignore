# Dependencies
node_modules/

# Environment files (contain secrets)
.env
.env.local
.env.production
.env.*.local

# Session files (authentication data - NEVER commit these)
sessions/
*.session
*.session-journal

# Log files
logs/
*.log

# Temporary files
temp/
tmp/
*.tmp
*.temp

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Build outputs
dist/
build/

# Test coverage
coverage/

# PM2
.pm2/

# Python virtual environment (for LibreTranslate)
.venv/
.venv-libretranslate/
__pycache__/
*.pyc

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Lock files (keep package-lock.json, ignore others)
# yarn.lock
# pnpm-lock.yaml
