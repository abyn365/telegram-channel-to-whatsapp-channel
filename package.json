{
  "name": "telegram-channel-to-whatsapp-channel",
  "version": "1.0.0",
  "description": "Userbot that forwards Telegram channel updates to a WhatsApp channel \u2014 supports text, images, videos, audio, documents, stickers, polls, locations, and more.",
  "main": "src/index.js",
  "scripts": {
    "start": "bash scripts/start.sh",
    "start:pm2": "pm2 startOrReload ecosystem.config.cjs --env production",
    "stop:pm2": "pm2 delete tg-wa-forwarder tg-wa-translator || true",
    "restart:pm2": "pm2 restart ecosystem.config.cjs --env production",
    "logs:pm2": "pm2 logs tg-wa-forwarder tg-wa-translator --lines 200",
    "list-chats": "node src/listChats.js",
    "follow-channel": "node src/followChannel.js",
    "test": "echo \"No tests defined\" && exit 0",
    "dashboard:dev": "npm --prefix dashboard run dev",
    "dashboard:build": "npm --prefix dashboard run build",
    "dashboard:start": "npm --prefix dashboard run start",
    "status:pm2": "pm2 ls"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abyn365/telegram-channel-to-whatsapp-channel.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "bugs": {
    "url": "https://github.com/abyn365/telegram-channel-to-whatsapp-channel/issues"
  },
  "homepage": "https://github.com/abyn365/telegram-channel-to-whatsapp-channel#readme",
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "dotenv": "^17.3.1",
    "fs-extra": "^11.3.3",
    "mime-types": "^3.0.2",
    "pino": "^10.3.1",
    "qrcode-terminal": "^0.12.0",
    "sharp": "^0.33.5",
    "telegram": "^2.26.22",
    "winston": "^3.19.0",
    "next": "^15.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
