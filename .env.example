# ─── Telegram API Credentials ───────────────────────────────────────────────
# Get these from https://my.telegram.org → API development tools
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_PHONE=+1234567890

# ─── Telegram Channels to Watch ─────────────────────────────────────────────
# Comma-separated list of channel usernames or IDs to monitor
# Examples: @mychannel, -1001234567890, mychannel
TELEGRAM_CHANNELS=@channel1,@channel2

# ─── WhatsApp Target Channel ─────────────────────────────────────────────────
# The WhatsApp channel/group ID to forward messages to.
# Run `npm run list-chats` after first login to find your channel ID.
#
# For WhatsApp Channels:
# - Use the full URL: https://whatsapp.com/channel/0029Vb7T8V460eBW2gKeNC1x
# - Or just the channel ID: 0029Vb7T8V460eBW2gKeNC1x
# - The code will automatically add @newsletter suffix
#
# For Groups:
# - Format: 120363xxxxxxxxxx@g.us
#
# Examples:
# WHATSAPP_TARGET_ID=https://whatsapp.com/channel/0029Vb7T8V460eBW2gKeNC1x
# WHATSAPP_TARGET_ID=0029Vb7T8V460eBW2gKeNC1x
# WHATSAPP_TARGET_ID=120363xxxxxxxxxx@g.us
WHATSAPP_TARGET_ID=

# ─── Optional Settings ────────────────────────────────────────────────────────
# Prefix added before each forwarded message (leave empty for none)
MESSAGE_PREFIX=

# Enable quote with source channel and author info (default: true)
INCLUDE_QUOTE=true

# Maximum file size in MB to forward (default: 50)
MAX_FILE_SIZE_MB=50

# Log level: error | warn | info | debug (default: info)
LOG_LEVEL=info


# WhatsApp backend provider: webjs (default) or waha
WHATSAPP_PROVIDER=webjs

# WAHA settings (used only when WHATSAPP_PROVIDER=waha)
# Example: http://127.0.0.1:3000/api
WAHA_BASE_URL=http://127.0.0.1:3000/api
WAHA_SESSION=default
