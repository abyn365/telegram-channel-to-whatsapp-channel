# ─── Telegram API Credentials ───────────────────────────────────────────────
# Get these from https://my.telegram.org → API development tools
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_PHONE=+1234567890

# ─── Telegram Channels to Watch ─────────────────────────────────────────────
# Comma-separated list of channel usernames or IDs to monitor
# Examples: @mychannel, -1001234567890, mychannel
TELEGRAM_CHANNELS=@channel1,@channel2

# ─── WhatsApp Target Channel ─────────────────────────────────────────────────
# The WhatsApp channel (newsletter) or group JID to forward messages to.
#
# For WhatsApp Channels (newsletters):
#   Run:  npm run list-chats https://whatsapp.com/channel/YOUR_INVITE_CODE
#   Copy the JID shown (e.g. 120363xxxxxxxxxx@newsletter)
#   Or use the invite URL / code — it will be auto-resolved on startup.
#
# For Groups:
#   Run:  npm run list-chats
#   Copy the group JID (format: 120363xxxxxxxxxx@g.us)
#
# Examples:
# WHATSAPP_TARGET_ID=https://whatsapp.com/channel/0029Vb7T8V460eBW2gKeNC1x
# WHATSAPP_TARGET_ID=120363282083849178@newsletter
# WHATSAPP_TARGET_ID=120363xxxxxxxxxx@g.us
WHATSAPP_TARGET_ID=

# ─── Message Formatting ──────────────────────────────────────────────────────

# Prefix added before each forwarded message (leave empty for none)
MESSAGE_PREFIX=

# Append source channel/author info as a quote block (default: true)
INCLUDE_QUOTE=true

# Maximum caption length for WhatsApp (default: 1024)
MAX_CAPTION_LENGTH=1024

# ─── Media Handling ─────────────────────────────────────────────────────────

# Maximum file size in MB to forward (default: 50, WhatsApp limit: 100)
MAX_FILE_SIZE_MB=50

# Media download timeout in milliseconds (default: 300000 = 5 minutes)
MEDIA_DOWNLOAD_TIMEOUT_MS=300000

# For WhatsApp channels/newsletters: "native", "document", or "hybrid"
# "native" = Try to send as viewable media (images/videos show inline) - may fail silently for channels
# "document" = Always send as downloadable files (reliable but requires tap to view)
# "hybrid" = Try native first, then fallback to document if it fails (recommended)
# Note: "native" often shows success but doesn't actually deliver to channels
# Default: hybrid (best balance between reliability and viewing experience)
NEWSLETTER_MEDIA_MODE=hybrid

# Send Telegram source link as extra text for media messages (default: true)
WHATSAPP_SEND_SOURCE_LINK=true

# DDL (Direct Download Link) Mode: Instead of downloading media from Telegram and
# re-uploading to WhatsApp, send the Telegram message link with caption.
# This is useful for:
#   - Large files (skip download/upload)
#   - Faster forwarding
#   - Avoiding native sending issues with WhatsApp channels
# Values: true/false (default: false)
WHATSAPP_DDL_MODE=false

# ─── Queue & Rate Limiting ──────────────────────────────────────────────────

# Delay between queued messages in milliseconds to avoid rate-limits (default: 1500)
SEND_DELAY_MS=1500

# Maximum messages in the send queue (default: 100)
MAX_QUEUE_SIZE=100

# Maximum retry attempts for failed messages (default: 3)
MAX_RETRIES=3

# Delay between retry attempts in milliseconds (default: 5000)
RETRY_DELAY_MS=5000

# ─── Telegram Polling (Fallback) ────────────────────────────────────────────

# Enable polling fallback for channels that might miss event updates (default: true)
TELEGRAM_POLLING_ENABLED=true

# Polling interval in milliseconds (default: 15000, minimum: 5000)
TELEGRAM_POLL_INTERVAL_MS=15000

# ─── Health Monitoring ──────────────────────────────────────────────────────

# Health check interval in milliseconds (default: 60000 = 1 minute)
HEALTH_CHECK_INTERVAL_MS=60000

# Log memory usage periodically (default: false)
LOG_MEMORY_USAGE=false

# ─── Translation (LibreTranslate) ───────────────────────────────────────────

# Enable/disable translation (default: true)
TRANSLATE_TO_ID=true

# LibreTranslate API URL
LIBRETRANSLATE_URL=http://127.0.0.1:5000/translate

# Source language for translation (default: auto-detect)
TRANSLATE_SOURCE=auto

# Target language for translation (default: id = Indonesian)
TRANSLATE_TARGET=id

# Prefix for translated text (default: id)
TRANSLATION_PREFIX=id

# Translation request timeout in milliseconds (default: 8000)
TRANSLATION_TIMEOUT_MS=8000

# If message has no raw text, translate caption as fallback (default: true)
TRANSLATE_USE_CAPTION_WHEN_EMPTY=true

# Maximum text length to translate (default: 5000)
MAX_TRANSLATION_LENGTH=5000

# ─── Forwarded Message Store ────────────────────────────────────────────────

# Maximum number of forwarded message keys to keep in memory (default: 50000)
MAX_FORWARDED_STORE_SIZE=50000

# Interval to persist forwarded keys to disk in milliseconds (default: 5000)
FORWARDED_PERSIST_INTERVAL_MS=5000

# Interval to cleanup old entries in milliseconds (default: 3600000 = 1 hour)
FORWARDED_CLEANUP_INTERVAL_MS=3600000

# ─── Logging ────────────────────────────────────────────────────────────────

# Log level: error | warn | info | debug (default: info)
LOG_LEVEL=info
